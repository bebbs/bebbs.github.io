<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="description" content="<%= site_tagline %>">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= stylesheet_link_tag "tailwind", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
    <%= yield :head %>
  </head>

  <body class="min-h-screen bg-paper text-ink antialiased">
    <div class="site-shell">
      <header class="site-header">
        <div class="space-y-5">
          <div class="flex flex-col gap-2">
            <%= link_to root_path, class: "site-title" do %>
              <%= image_tag "icons/terminal.svg", class: "w-8 h-8" %>
              <span class="site-title-wordmark"><%= site_title %></span>
            <% end %>
            <p class="max-w-2xl text-base leading-7 text-stone-600"><%= site_tagline %></p>
          </div>

          <nav class="flex flex-wrap items-center gap-x-5 gap-y-2">
            <%= link_to "Tags", tags_path, class: nav_link_classes(tags_path) %>
            <% if site_pages.any? %>
              <% site_pages.each do |page| %>
                <%= link_to page.title, page_path(page.slug), class: nav_link_classes(page.path) %>
              <% end %>
            <% end %>
          </nav>
        </div>
      </header>

      <main>
        <%= yield %>
      </main>

      <footer class="site-footer">
        <p>Built with Rails, markdown files, and Parklife.</p>
      </footer>
    </div>
  </body>
</html>
