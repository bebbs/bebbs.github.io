<?xml version="1.0" encoding="UTF-8"?>
<rss version="2.0" xmlns:atom="http://www.w3.org/2005/Atom">
  <channel>
    <title><%= ERB::Util.h(site_title) %></title>
    <description><%= ERB::Util.h(site_tagline) %></description>
    <link><%= absolute_url_for(root_path) %></link>
    <language>en-gb</language>
    <atom:link href="<%= absolute_url_for(feed_path(format: :xml)) %>" rel="self" type="application/rss+xml" />
    <% if @posts.any? %>
      <lastBuildDate><%= @posts.first.published_at.rfc2822 %></lastBuildDate>
    <% end %>
    <% @posts.each do |post| %>
      <item>
        <title><%= ERB::Util.h(post.title) %></title>
        <link><%= absolute_url_for(post.path) %></link>
        <guid isPermaLink="true"><%= absolute_url_for(post.path) %></guid>
        <pubDate><%= post.published_at.rfc2822 %></pubDate>
        <description><%= ERB::Util.h(post.summary) %></description>
        <% post.tags.each do |tag| %>
          <category><%= ERB::Util.h(tag) %></category>
        <% end %>
      </item>
    <% end %>
  </channel>
</rss>
